	 /*
	  * 设置sbi的加载入口地址为0x80000000
	  */

	. = 0x80000000;

	.text.boot : { *(.text.boot) }   /*启动的代码段*/
	.text : { *(.text) }    /*代码段*/
	.rodata : { *(.rodata)}     /*只读数据段*/
	.data : { *(.data) }   /*该段用于存放初始化的数据。通常包含程序中已初始化的全局变量和静态变量等。*/
	. = ALIGN(0x8);
	bss_begin = .;
	.bss : { *(.bss*) }  /*用于存放未初始化的全局变量和静态变量。程序启动时，.bss 段的内容会被清零。*/
	bss_end = .;
